<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TMS</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="nav">
            <a asp-page="/Index">My Calendar</a>
            <a asp-page="/Consolidated">Consolidated View</a>
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <span class="user-chip">@User.Identity?.Name</span>
                <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut">Sign out</a>
            }
            else
            {
                <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn">Sign in</a>
            }
        </nav>
    </header>
    <main class="container">
        @RenderBody()
    </main>
</body>
</html>
